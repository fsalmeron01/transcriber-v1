# App
NODE_ENV=production
PORT=3000
APP_URL=http://web.home119.cloud
NEXT_PUBLIC_APP_URL=http://web.home119.cloud

# Database
POSTGRES_DB=transcriber
POSTGRES_USER=transcriber
POSTGRES_PASSWORD=ChangeThisToAStrongPassword123!
DATABASE_URL=postgresql://transcriber:ChangeThisToAStrongPassword123!@postgres:5432/transcriber

# Queue
REDIS_URL=redis://redis:6379

# Storage
STORAGE_ROOT=/data
PUBLIC_DOWNLOAD_BASE_URL=http://web.home119.cloud

# Media / Transcription
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
MAX_SOURCE_URL_LENGTH=2048
YTDLP_FORMAT=bestaudio/best

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
